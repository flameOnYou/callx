#!/usr/bin/env node

const { CONFIG_BASE, PROVIDERS_FILE } = require("./lib/runtime");

function showHelp() {
  console.log(`callcli - callx 的交互式 TUI 配置器

用法:
  callcli
  callcli --help

说明:
  - 基于 Ink 构建的交互式 TUI
  - 启动智能体支持两步式选择：先选 sprite，再选普通执行 / 自动化执行
  - Provider 管理支持 name / remark / url / api_key / format 的美观编辑
  - 智能体管理支持 provider / skill / MCP / CLI / model / autoupdate
  - Worktree 创建完成后可直接进入新目录下的子 shell

配置目录:
  ${CONFIG_BASE}
  ${PROVIDERS_FILE}`);
}

async function main() {
  const args = process.argv.slice(2);
  if (args.includes("-h") || args.includes("--help") || args.includes("help")) {
    showHelp();
    return;
  }

  try {
    const { runCallCli } = await import("./lib/callcli/app.mjs");
    await runCallCli();
  } catch (error) {
    console.error(error?.message || String(error));
    process.exit(1);
  }
}

main();
