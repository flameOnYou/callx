async function deleteSpriteFlow(tui, spriteName) {
  const spriteNames = listSpriteNames();
  const isDefault = getDefault() === spriteName;
  let nextDefault = "";

  if (isDefault && spriteNames.length > 1) {
    nextDefault = await tui.select({
      title: "当前删除的是默认智能体",
      description: ["请选择新的默认智能体，或清空默认设置。"],
      items: [
        { label: "清空默认设置", value: "__CLEAR__" },
        ...spriteNames.filter((name) => name !== spriteName).map((name) => ({ label: name, value: name })),
      ],
    });
    if (nextDefault === null) {
      return;
    }
  }

  const confirmed = await tui.confirm({
    title: "确认删除智能体",
    lines: [`将删除 sprite '${spriteName}' 目录及其配置。`],
    confirmLabel: "删除",
  });
  if (!confirmed) {
    return;
  }

  deleteSprite(spriteName);
  if (isDefault) {
    if (nextDefault && nextDefault !== "__CLEAR__") {
      setDefault(nextDefault);
    } else {
      clearDefault();
    }
  }

  await tui.message({
    title: "智能体已删除",
    lines: [`${spriteName} 已移除。`],
  });
}

async function spritesMenu(tui) {
  while (true) {
    const defaultSprite = getDefault();
    const spriteNames = listSpriteNames();
    const selected = await tui.select({
      title: "智能体管理",
      description: ["这里所有主要配置都走列表选择，不要求用户打字。"],
      items: [
        { label: "新建智能体", value: "__create__", hint: "支持空白创建或复制现有智能体" },
        ...spriteNames.map((name) => {
          const config = getSpriteConfig(name);
          return {
            label: name === defaultSprite ? `${name} [默认]` : name,
            value: name,
            hint: `${config.cli || "opencode"}  ${config.provider || "-"}  ${config.model || "-"}`,
          };
        }),
        { label: "返回主菜单", value: "__back__" },
      ],
    });

    if (selected === null || selected === "__back__") {
      return;
    }
    if (selected === "__create__") {
      await createSpriteFlow(tui);
      continue;
    }

    const action = await tui.select({
      title: `智能体: ${selected}`,
      items: [
        { label: "查看详情", value: "show" },
        { label: "切换供应商", value: "provider" },
        { label: "配置技能", value: "skills" },
        { label: "配置 MCP", value: "mcp" },
        { label: "切换 CLI", value: "cli" },
        { label: "切换 Model", value: "model" },
        { label: "切换 Autoupdate", value: "autoupdate" },
        { label: "设为默认", value: "default" },
        { label: "删除智能体", value: "delete" },
        { label: "返回", value: "back" },
      ],
    });

    if (action === null || action === "back") {
      continue;
    }
    if (action === "show") {
      await showSpriteDetails(tui, selected);
      continue;
    }
    if (action === "provider") {
      await setSpriteProviderFlow(tui, selected);
      continue;
    }
    if (action === "skills") {
      await setSpriteSkillsFlow(tui, selected);
      continue;
    }
    if (action === "mcp") {
      await setSpriteMcpFlow(tui, selected);
      continue;
    }
    if (action === "cli") {
      await setSpriteCliFlow(tui, selected);
      continue;
    }
    if (action === "model") {
      await setSpriteModelFlow(tui, selected);
      continue;
    }
    if (action === "autoupdate") {
      await setSpriteAutoupdateFlow(tui, selected);
      continue;
    }
    if (action === "default") {
      setDefault(selected);
      await tui.message({
        title: "默认智能体已更新",
        lines: [`${selected} 已设为默认 sprite。`],
      });
      continue;
    }
    if (action === "delete") {
      await deleteSpriteFlow(tui, selected);
    }
  }
}

async function worktreeMenu(tui) {
  const repoRoot = findGitRoot(process.cwd());
  if (!repoRoot) {
    await tui.message({
      title: "当前不在 Git 仓库中",
      lines: ["请先 `cd` 到一个 git 工作目录，再打开 callcli。"],
    });
    return "";
  }

  while (true) {
    const currentBranch = getCurrentBranch(repoRoot) || "HEAD(detached)";
    const action = await tui.select({
      title: "Worktree 创建器",
      description: [
        `仓库: ${repoRoot}`,
        `当前分支: ${currentBranch}`,
        "直接修改父 shell 的 cwd 做不到，所以这里支持创建后进入新 worktree 的子 shell。",
      ],
      items: [
        { label: "基于当前分支新建 worktree", value: "new" },
        { label: "使用现有分支创建 worktree", value: "existing" },
        { label: "查看现有 worktree", value: "list" },
        { label: "返回主菜单", value: "back" },
      ],
    });

    if (action === null || action === "back") {
      return "";
    }

    if (action === "list") {
      const worktrees = listWorktrees(repoRoot);
      await tui.message({
        title: "现有 Worktree",
        lines: worktrees.length > 0
          ? worktrees.map((item) => `${item.branch || "detached"} -> ${item.path}`)
          : ["当前仓库还没有额外 worktree。"],
      });
      continue;
    }

    if (action === "new") {
      const suggestedBranch = ensureUniqueBranchName(repoRoot, suggestBranchName(repoRoot));
      const branchName = await tui.input({
        title: "新建分支并创建 Worktree",
        description: ["默认使用 codex/ 前缀。", "你也可以在这里覆盖为任意合法分支名。"],
        label: "分支名",
        defaultValue: suggestedBranch,
      });
      if (branchName === null) {
        continue;
      }
      const worktreePath = await tui.input({
        title: "设置 Worktree 目录",
        description: ["默认放在当前仓库同级目录。"],
        label: "目录",
        defaultValue: suggestWorktreePath(repoRoot, branchName),
      });
      if (worktreePath === null) {
        continue;
      }

      const confirmed = await tui.confirm({
        title: "确认创建 Worktree",
        lines: [
          `仓库: ${repoRoot}`,
          `新分支: ${branchName}`,
          `目录: ${worktreePath}`,
        ],
        confirmLabel: "创建",
      });
      if (!confirmed) {
        continue;
      }

      createWorktreeForNewBranch(repoRoot, branchName.trim(), path.resolve(worktreePath.trim()), getCurrentBranch(repoRoot) || "HEAD");
      const nextAction = await tui.select({
        title: "Worktree 已创建",
        description: [path.resolve(worktreePath.trim())],
        items: [
          { label: "进入新 worktree 的 shell", value: "shell" },
          { label: "返回主菜单", value: "back" },
        ],
      });
      if (nextAction === "shell") {
        return path.resolve(worktreePath.trim());
      }
      continue;
    }

    if (action === "existing") {
      const branches = getAvailableBranchesForWorktree(repoRoot);
      if (branches.length === 0) {
        await tui.message({
          title: "没有可用分支",
          lines: ["所有本地分支都已经被某个 worktree 占用，或者仓库里还没有分支。"],
        });
        continue;
      }

      const branchName = await tui.select({
        title: "选择现有分支",
        items: branches.map((branch) => ({ label: branch, value: branch })),
      });
      if (branchName === null) {
        continue;
      }
      const worktreePath = await tui.input({
        title: "设置 Worktree 目录",
        description: ["默认放在当前仓库同级目录。"],
        label: "目录",
        defaultValue: suggestWorktreePath(repoRoot, branchName),
      });
      if (worktreePath === null) {
        continue;
      }

      const confirmed = await tui.confirm({
        title: "确认创建 Worktree",
        lines: [
          `现有分支: ${branchName}`,
          `目录: ${worktreePath}`,
        ],
        confirmLabel: "创建",
      });
      if (!confirmed) {
        continue;
      }

      createWorktreeForExistingBranch(repoRoot, branchName, path.resolve(worktreePath.trim()));
      const nextAction = await tui.select({
        title: "Worktree 已创建",
        description: [path.resolve(worktreePath.trim())],
        items: [
          { label: "进入新 worktree 的 shell", value: "shell" },
          { label: "返回主菜单", value: "back" },
        ],
      });
      if (nextAction === "shell") {
        return path.resolve(worktreePath.trim());
      }
    }
  }
}

async function runTui() {
  const bootstrapped = ensureReady();
  if (!listProviderNames().length && !listSpriteNames().length) {
    fail(`初始化配置失败，请检查 ${CONFIG_BASE}`);
  }

  const tui = new TerminalUI();
  let shellPath = "";
  try {
    tui.enter();
    if (bootstrapped) {
      await tui.message({
        title: "已初始化配置目录",
        lines: [
          CONFIG_BASE,
          "基础 providers / sprites / skillpacks / mcpservers 已复制到用户配置目录。",
        ],
      });
    }

    while (true) {
      const action = await tui.select({
        title: "callcli",
        description: [
          "进入后先选择要做的事。",
          `配置目录: ${CONFIG_BASE}`,
        ],
        footer: [
          "↑/↓ 选择  Enter 确认",
          "Esc 退出",
        ],
        items: [
          { label: "编辑大模型供应商", value: "providers", hint: "name / remark / url / api_key / format 的增删改查" },
          { label: "编辑智能体", value: "sprites", hint: "通过列表配置 provider / skill / MCP / CLI / model" },
          { label: "创建 Worktree", value: "worktree", hint: "常用 git worktree add 的交互封装" },
          { label: "退出", value: "exit" },
        ],
      });

      if (action === null || action === "exit") {
        break;
      }
      if (action === "providers") {
        await providersMenu(tui);
        continue;
      }
      if (action === "sprites") {
        await spritesMenu(tui);
        continue;
      }
      if (action === "worktree") {
        shellPath = await worktreeMenu(tui);
        if (shellPath) {
          break;
        }
      }
    }
  } finally {
    tui.leave();
  }

  if (shellPath) {
    launchShell(shellPath);
  }
}

async function main() {
  const args = process.argv.slice(2);
  if (args.includes("-h") || args.includes("--help") || args.includes("help")) {
    showHelp();
    return;
  }

  try {
    await runTui();
  } catch (error) {
    fail(error.message);
  }
}

main();
