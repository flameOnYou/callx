async function editProviderForm(tui, originalName = "") {
  const provider = originalName ? getProvider(originalName) : {};

  while (true) {
    const name = await tui.input({
      title: originalName ? "编辑 Provider" : "新建 Provider",
      description: ["Provider 名会被 sprite 的 provider 字段引用。"],
      label: "名称",
      defaultValue: originalName,
    });
    if (name === null) {
      return null;
    }
    const trimmedName = sanitizeName(name, "");
    if (!trimmedName) {
      continue;
    }
    if (trimmedName !== originalName && listProviderNames().includes(trimmedName)) {
      await tui.message({
        title: "名称已存在",
        lines: [`provider '${trimmedName}' 已存在，请换一个名字。`],
      });
      continue;
    }

    const format = await chooseProviderFormat(tui, provider.format || "openai");
    if (format === null) {
      return null;
    }
    const baseUrl = await tui.input({
      title: originalName ? "编辑 Provider" : "新建 Provider",
      label: "Base URL",
      defaultValue: provider.base_url || "",
    });
    if (baseUrl === null) {
      return null;
    }
    const apiKey = await tui.input({
      title: originalName ? "编辑 Provider" : "新建 Provider",
      label: "API Key",
      defaultValue: provider.api_key || "",
      secret: true,
      allowEmpty: true,
    });
    if (apiKey === null) {
      return null;
    }
    const remark = await tui.input({
      title: originalName ? "编辑 Provider" : "新建 Provider",
      label: "备注",
      defaultValue: provider.remark || "",
      allowEmpty: true,
      placeholder: "可留空",
    });
    if (remark === null) {
      return null;
    }

    return {
      name: trimmedName,
      config: {
        base_url: baseUrl.trim(),
        api_key: apiKey,
        format,
        remark: remark.trim(),
      },
    };
  }
}

async function showProviderDetails(tui, providerName) {
  const provider = getProvider(providerName);
  const referencedBy = getReferencingSprites(providerName);
  await tui.message({
    title: `Provider: ${providerName}`,
    lines: [
      `format: ${provider.format || "-"}`,
      `base_url: ${provider.base_url || "-"}`,
      `api_key: ${provider.api_key ? "已配置" : "-"}`,
      `remark: ${provider.remark || "-"}`,
      `被以下智能体引用: ${referencedBy.length > 0 ? referencedBy.join(", ") : "-"}`,
    ],
  });
}

async function saveProviderChanges(tui, originalName) {
  const result = await editProviderForm(tui, originalName);
  if (!result) {
    return;
  }

  const providers = getProviders();
  const { name, config } = result;

  if (originalName && name !== originalName) {
    delete providers[originalName];
    for (const spriteName of getReferencingSprites(originalName)) {
      const spriteConfig = getSpriteConfig(spriteName);
      spriteConfig.provider = name;
      saveSpriteConfig(spriteName, normalizeSpriteConfig(spriteConfig));
    }
  }

  providers[name] = config;
  saveProviders(providers);

  await tui.message({
    title: originalName ? "Provider 已更新" : "Provider 已创建",
    lines: [`${name} 已写入 ${PROVIDERS_FILE}`],
  });
}

async function deleteProviderFlow(tui, providerName) {
  const referenced = getReferencingSprites(providerName);
  const providers = getProviders();

  if (referenced.length > 0) {
    const replacement = await tui.select({
      title: "Provider 正在被使用",
      description: [
        `以下智能体正在引用 ${providerName}: ${referenced.join(", ")}`,
        "删除前请先为它们选择一个替代 provider，或者清空 provider。",
      ],
      items: [
        { label: "清空这些智能体的 provider", value: "__CLEAR__", hint: "删除后相关 sprite 将不再绑定 provider" },
        ...listProviderNames()
          .filter((name) => name !== providerName)
          .map((name) => ({ label: name, value: name, hint: getProvider(name).remark || "-" })),
      ],
    });

    if (replacement === null) {
      return;
    }

    for (const spriteName of referenced) {
      const spriteConfig = getSpriteConfig(spriteName);
      if (replacement === "__CLEAR__") {
        delete spriteConfig.provider;
      } else {
        spriteConfig.provider = replacement;
      }
      saveSpriteConfig(spriteName, normalizeSpriteConfig(spriteConfig));
    }
  }

  const confirmed = await tui.confirm({
    title: "确认删除 Provider",
    lines: [`将删除 provider '${providerName}'。`],
    confirmLabel: "删除",
  });
  if (!confirmed) {
    return;
  }

  delete providers[providerName];
  saveProviders(providers);
  await tui.message({
    title: "Provider 已删除",
    lines: [`${providerName} 已从 providers.json 中移除。`],
  });
}

async function providersMenu(tui) {
  while (true) {
    const providerNames = listProviderNames();
    const selected = await tui.select({
      title: "Provider 管理",
      description: [`配置文件: ${PROVIDERS_FILE}`],
      items: [
        { label: "新建 Provider", value: "__create__", hint: "新增一条 provider 配置" },
        ...providerNames.map((name) => {
          const provider = getProvider(name);
          return {
            label: name,
            value: name,
            hint: `${provider.format || "openai"}  ${provider.remark || "-"}`,
          };
        }),
        { label: "返回主菜单", value: "__back__" },
      ],
    });

    if (selected === null || selected === "__back__") {
      return;
    }
    if (selected === "__create__") {
      await saveProviderChanges(tui, "");
      continue;
    }

    const action = await tui.select({
      title: `Provider: ${selected}`,
      items: [
        { label: "查看详情", value: "show" },
        { label: "编辑", value: "edit" },
        { label: "删除", value: "delete" },
        { label: "返回", value: "back" },
      ],
    });

    if (action === null || action === "back") {
      continue;
    }
    if (action === "show") {
      await showProviderDetails(tui, selected);
      continue;
    }
    if (action === "edit") {
      await saveProviderChanges(tui, selected);
      continue;
    }
    if (action === "delete") {
      await deleteProviderFlow(tui, selected);
    }
  }
}

