async function createSpriteFlow(tui) {
  const spriteNames = listSpriteNames();
  const createMode = await tui.select({
    title: "新建智能体",
    description: ["智能体创建流程尽量避免打字，默认使用自动生成名称。"],
    items: [
      { label: "从空白模板创建", value: "blank" },
      ...(spriteNames.length > 0 ? [{ label: "复制现有智能体后调整", value: "clone", hint: "最适合快速起一个变体" }] : []),
      { label: "返回", value: "back" },
    ],
  });

  if (createMode === null || createMode === "back") {
    return;
  }

  let sourceName = "";
  let sourceConfig = {};
  if (createMode === "clone") {
    sourceName = await tui.select({
      title: "选择模板智能体",
      items: spriteNames.map((name) => ({
        label: name,
        value: name,
        hint: `${getSpriteConfig(name).cli || "opencode"}  ${getSpriteConfig(name).provider || "-"}`,
      })),
    });
    if (sourceName === null) {
      return;
    }
    sourceConfig = getSpriteConfig(sourceName);
  }

  const cli = await chooseCli(tui, sourceConfig.cli || "opencode");
  if (cli === null) {
    return;
  }
  const provider = await chooseProvider(tui, cli, sourceConfig.provider || "");
  if (provider === null) {
    return;
  }
  const model = await chooseModel(tui, cli, provider, sourceConfig.model || "");
  if (model === null) {
    return;
  }
  const autoupdate = await chooseBoolean(tui, "设置 autoupdate", ["这里只写入 config.json，不会立即执行更新。"], Boolean(sourceConfig.autoupdate));
  if (autoupdate === null) {
    return;
  }
  const skillLinks = await chooseSkills(tui, Array.isArray(sourceConfig.skill_links) ? sourceConfig.skill_links : []);
  const mcpLinks = await chooseMcps(tui, Array.isArray(sourceConfig.mcp_links) ? sourceConfig.mcp_links : []);

  const suggestedName = uniqueName(buildSpriteBaseName(sourceName, provider, cli), spriteNames);
  const createAction = await chooseSpriteDefaultsAction(tui, suggestedName);
  if (createAction === null || createAction === "cancel") {
    return;
  }

  createSpriteFromTemplate(suggestedName, sourceName);
  const nextConfig = normalizeSpriteConfig({
    ...sourceConfig,
    cli,
    provider,
    model,
    autoupdate,
    skill_links: skillLinks,
    mcp_links: mcpLinks,
  });
  saveSpriteConfig(suggestedName, nextConfig);
  syncSkills(suggestedName);

  if (createAction === "create-default") {
    setDefault(suggestedName);
  }

  await tui.message({
    title: "智能体已创建",
    lines: [
      `名称: ${suggestedName}`,
      `CLI: ${cli}`,
      `Provider: ${provider || "-"}`,
      `Model: ${model || "-"}`,
    ],
  });
}

