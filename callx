#!/usr/bin/env node

const fs = require("fs");
const path = require("path");
const os = require("os");
const { spawnSync } = require("child_process");

const SCRIPT_DIR = __dirname;
const CONFIG_BASE = path.join(process.env.XDG_CONFIG_HOME || path.join(os.homedir(), ".config"), "callx");
const SPRITES_DIR = path.join(CONFIG_BASE, "sprites");
const SKILLPACKS_DIR = path.join(CONFIG_BASE, "skillpacks");
const PROVIDERS_FILE = path.join(CONFIG_BASE, "providers.json");
const DEFAULT_FILE = path.join(CONFIG_BASE, ".default");
const PACKAGE_NAME = "@greenhill/callx";
const COMMAND_NAME = "call";

function fileExists(target) {
  return fs.existsSync(target);
}

function readJson(file) {
  try {
    return JSON.parse(fs.readFileSync(file, "utf8"));
  } catch {
    return {};
  }
}

function ensureDir(dir) {
  fs.mkdirSync(dir, { recursive: true });
}

function copyMissing(srcRoot, dstRoot) {
  if (!fileExists(srcRoot)) {
    return;
  }
  ensureDir(dstRoot);
  for (const entry of fs.readdirSync(srcRoot, { withFileTypes: true })) {
    const src = path.join(srcRoot, entry.name);
    const dst = path.join(dstRoot, entry.name);
    if (fileExists(dst)) {
      continue;
    }
    if (entry.isDirectory()) {
      fs.cpSync(src, dst, { recursive: true });
    } else {
      fs.copyFileSync(src, dst);
    }
  }
}

function bootstrapConfigIfMissing() {
  const needsBootstrap = !fileExists(PROVIDERS_FILE) || !fileExists(SPRITES_DIR) || !fileExists(SKILLPACKS_DIR);
  if (!needsBootstrap) {
    return false;
  }

  ensureDir(CONFIG_BASE);
  ensureDir(SPRITES_DIR);
  ensureDir(SKILLPACKS_DIR);

  const providersSeed = path.join(SCRIPT_DIR, "providers.example.json");
  if (fileExists(providersSeed) && !fileExists(PROVIDERS_FILE)) {
    fs.copyFileSync(providersSeed, PROVIDERS_FILE);
  }

  copyMissing(path.join(SCRIPT_DIR, "sprites"), SPRITES_DIR);
  copyMissing(path.join(SCRIPT_DIR, "skillpacks"), SKILLPACKS_DIR);
  copyMissing(path.join(SCRIPT_DIR, "mcpservers"), path.join(CONFIG_BASE, "mcpservers"));

  if (!fileExists(DEFAULT_FILE) && fileExists(path.join(SPRITES_DIR, "open-01"))) {
    fs.writeFileSync(DEFAULT_FILE, "open-01\n", "utf8");
  }

  return true;
}

function getDefault() {
  if (!fileExists(DEFAULT_FILE)) {
    return "";
  }
  return fs.readFileSync(DEFAULT_FILE, "utf8").trim();
}

function setDefault(name) {
  const dir = path.join(SPRITES_DIR, name);
  if (!fileExists(dir)) {
    fail(`错误: sprite '${name}' 不存在`);
  }
  fs.writeFileSync(DEFAULT_FILE, `${name}\n`, "utf8");
  console.log(`已设为默认 sprite: ${name}`);
}

function getSpriteConfig(sprite) {
  return readJson(path.join(SPRITES_DIR, sprite, "config.json"));
}

function getCli(sprite) {
  const config = getSpriteConfig(sprite);
  return config.cli || "opencode";
}

function getProviderValue(providerName, field) {
  const providers = readJson(PROVIDERS_FILE);
  return providers[providerName]?.[field] || "";
}

function getProvider(providerName) {
  const providers = readJson(PROVIDERS_FILE);
  return providers[providerName] || {};
}

function ensureReady() {
  const bootstrapped = bootstrapConfigIfMissing();
  if (bootstrapped) {
    console.error(`已初始化配置目录: ${CONFIG_BASE}`);
    console.error(`请编辑: ${PROVIDERS_FILE}`);
  }
  if (!fileExists(PROVIDERS_FILE)) {
    fail(`错误: 未找到 ${PROVIDERS_FILE}`);
  }
}

function getSubSkills(dir) {
  const subs = [];
  for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
    if (entry.isDirectory() && fileExists(path.join(dir, entry.name, "SKILL.md"))) {
      subs.push(entry.name);
    }
  }
  return subs;
}

function syncSkills(sprite) {
  const config = getSpriteConfig(sprite);
  const links = Array.isArray(config.skill_links) ? config.skill_links : [];
  const skillsDir = path.join(SPRITES_DIR, sprite, "skills");
  ensureDir(skillsDir);

  const expectedLinks = new Set();

  for (const skill of links) {
    if (skill.includes("/")) {
      const target = path.join(SKILLPACKS_DIR, skill);
      if (!fileExists(target)) {
        console.error(`警告: skillpacks 中不存在技能 '${skill}'，跳过`);
        continue;
      }
      const linkName = path.basename(skill);
      expectedLinks.add(linkName);
      const link = path.join(skillsDir, linkName);
      if (fileExists(link)) {
        fs.rmSync(link, { recursive: true, force: true });
      }
      const type = process.platform === "win32" ? "junction" : "dir";
      fs.symlinkSync(target, link, type);
    } else {
      const target = path.join(SKILLPACKS_DIR, skill);
      if (!fileExists(target)) {
        console.error(`警告: skillpacks 中不存在技能 '${skill}'，跳过`);
        continue;
      }
      const subs = getSubSkills(target);
      if (subs.length > 0) {
        for (const sub of subs) {
          expectedLinks.add(sub);
          const link = path.join(skillsDir, sub);
          if (fileExists(link)) {
            fs.rmSync(link, { recursive: true, force: true });
          }
          const type = process.platform === "win32" ? "junction" : "dir";
          fs.symlinkSync(path.join(target, sub), link, type);
        }
      } else {
        expectedLinks.add(skill);
        const link = path.join(skillsDir, skill);
        if (fileExists(link)) {
          fs.rmSync(link, { recursive: true, force: true });
        }
        const type = process.platform === "win32" ? "junction" : "dir";
        fs.symlinkSync(target, link, type);
      }
    }
  }

  for (const entry of fs.readdirSync(skillsDir, { withFileTypes: true })) {
    const fullPath = path.join(skillsDir, entry.name);
    if (!expectedLinks.has(entry.name) && fs.lstatSync(fullPath).isSymbolicLink()) {
      fs.unlinkSync(fullPath);
    }
  }
}

function syncMcp(sprite) {
  const config = getSpriteConfig(sprite);
  const links = Array.isArray(config.mcp_links) ? config.mcp_links : [];
  if (links.length === 0) return {};

  const servers = {};
  for (const name of links) {
    const mcpFile = path.join(CONFIG_BASE, "mcpservers", name, "mcp.json");
    if (!fileExists(mcpFile)) {
      console.error(`警告: mcpservers 中不存在 MCP 服务器 '${name}'，跳过`);
      continue;
    }
    const def = readJson(mcpFile);
    if (def.enabled === false) continue;
    servers[name] = def;
  }
  return servers;
}

function buildClaudeMcpJson(servers) {
  const result = {};
  for (const [name, def] of Object.entries(servers)) {
    if (def.type === "remote") {
      result[name] = { type: "http", url: def.url };
      if (def.headers) result[name].headers = def.headers;
    } else {
      result[name] = { command: def.command, args: def.args || [] };
      if (def.env && Object.keys(def.env).length > 0) {
        result[name].env = def.env;
      }
    }
  }
  return result;
}

function buildOpenCodeMcp(servers) {
  const result = {};
  for (const [name, def] of Object.entries(servers)) {
    if (def.type === "remote") {
      const entry = { type: "remote", url: def.url };
      if (def.headers) entry.headers = def.headers;
      if (def.oauth) entry.oauth = def.oauth;
      result[name] = entry;
    } else {
      const cmdArray = [def.command, ...(def.args || [])];
      const entry = { type: "local", command: cmdArray, enabled: true };
      if (def.env && Object.keys(def.env).length > 0) {
        entry.environment = def.env;
      }
      if (def.timeout) entry.timeout = def.timeout;
      result[name] = entry;
    }
  }
  return result;
}

function buildOpenCodeConfig(sprite, autoMode) {
  const spriteCfg = getSpriteConfig(sprite);
  const providers = readJson(PROVIDERS_FILE);
  const providerName = spriteCfg.provider || "";

  const config = {
    $schema: "https://opencode.ai/config.json",
  };

  if (spriteCfg.model) {
    config.model = spriteCfg.model;
  }
  if (spriteCfg.autoupdate) {
    config.autoupdate = spriteCfg.autoupdate;
  }
  if (Array.isArray(spriteCfg.skill_links) && spriteCfg.skill_links.length > 0) {
    config.skills = { paths: ["./skills"] };
  } else if (spriteCfg.skills) {
    config.skills = spriteCfg.skills;
  }

  if (providerName && providers[providerName]) {
    const prov = providers[providerName];
    if (prov.format === "anthropic") {
      config.provider = {
        anthropic: {
          options: {
            apiKey: prov.api_key || "",
            baseURL: prov.base_url || "",
          },
        },
      };
    } else {
      config.provider = {
        [providerName]: {
          options: {
            apiKey: prov.api_key || "",
            baseURL: prov.base_url || "",
          },
        },
      };
    }
  }

  if (autoMode) {
    config.permission = "allow";
  }

  const mcpServers = syncMcp(sprite);
  if (Object.keys(mcpServers).length > 0) {
    config.mcp = buildOpenCodeMcp(mcpServers);
  }

  return JSON.stringify(config);
}

function listSprites() {
  ensureReady();
  console.log("可用 sprites:");
  if (!fileExists(SPRITES_DIR)) {
    return;
  }

  for (const entry of fs.readdirSync(SPRITES_DIR, { withFileTypes: true })) {
    if (!entry.isDirectory()) {
      continue;
    }
    const name = entry.name;
    const config = getSpriteConfig(name);
    const cli = config.cli || "opencode";
    const provider = config.provider || "-";
    const model = config.model || "-";
    const mcpCount = Array.isArray(config.mcp_links) ? config.mcp_links.length : 0;
    console.log(`  ${name.padEnd(20)} [${cli.padEnd(10)}] provider=${provider.padEnd(12)} model=${model} mcp=${mcpCount}`);
  }
}

function showCurrent(selectedSprite) {
  ensureReady();
  const current = selectedSprite || getDefault();
  if (!current) {
    fail(`未设置默认 sprite，请先运行 ${COMMAND_NAME} -d <名>`);
  }

  const config = getSpriteConfig(current);
  const provider = config.provider || "-";
  const baseUrl = provider !== "-" ? getProviderValue(provider, "base_url") || "-" : "-";
  const providerRemark = provider !== "-" ? getProvider(provider).remark || "-" : "-";

  console.log(`当前 sprite: ${current}`);
  console.log(`  CLI:      ${config.cli || "opencode"}`);
  console.log(`  Provider: ${provider}`);
  console.log(`  Remark:   ${providerRemark}`);
  console.log(`  Model:    ${config.model || "-"}`);
  console.log(`  Base URL: ${baseUrl}`);
  console.log("  Key:      (stored in providers.json)");
  const mcpLinks = Array.isArray(config.mcp_links) ? config.mcp_links : [];
  console.log(`  MCP:      ${mcpLinks.length > 0 ? mcpLinks.join(", ") : "-"}`);
}

function showHelp() {
  console.log(`callx — AI 环境切换工具（支持 claude / opencode）

用法:
  ${COMMAND_NAME} [选项] [sprite 名] [-- 参数...]

选项:
  -l, --list          列出所有可用 sprite
  -d, --default <名>  设置默认 sprite
  -a, --auto          自动执行模式
  -s, --show          显示当前 sprite 配置
  update              通过 npm 更新 ${COMMAND_NAME}
  -h, --help          显示帮助

示例:
  ${COMMAND_NAME} -l
  ${COMMAND_NAME} -d open-01
  ${COMMAND_NAME}
  ${COMMAND_NAME} claude-01
  ${COMMAND_NAME} open-01 -a run "hi"
  ${COMMAND_NAME} update`);
}

function fail(message) {
  console.error(message);
  process.exit(1);
}

function runCommand(command, args, extraEnv = {}) {
  const result = spawnSync(command, args, {
    stdio: "inherit",
    env: { ...process.env, ...extraEnv },
  });

  if (result.error) {
    if (result.error.code === "ENOENT") {
      fail(`错误: 未找到命令 '${command}'`);
    }
    fail(result.error.message);
  }

  process.exit(result.status === null ? 1 : result.status);
}

function updateSelf() {
  const npmCmd = process.platform === "win32" ? "npm.cmd" : "npm";
  runCommand(npmCmd, ["install", "-g", `${PACKAGE_NAME}@latest`]);
}

function parseArgs(rawArgs) {
  const state = {
    sprite: "",
    autoMode: false,
    show: false,
    list: false,
    setDefault: "",
    forwardArgs: [],
  };

  let i = 0;
  while (i < rawArgs.length) {
    const arg = rawArgs[i];
    if (arg === "update") {
      updateSelf();
    }
    if (arg === "-l" || arg === "--list") {
      state.list = true;
      i += 1;
      continue;
    }
    if (arg === "-s" || arg === "--show") {
      state.show = true;
      i += 1;
      continue;
    }
    if (arg === "-h" || arg === "--help") {
      showHelp();
      process.exit(0);
    }
    if (arg === "-a" || arg === "--auto") {
      state.autoMode = true;
      i += 1;
      continue;
    }
    if (arg === "-d" || arg === "--default") {
      if (!rawArgs[i + 1]) {
        fail("错误: --default 需要一个 sprite 名称");
      }
      state.setDefault = rawArgs[i + 1];
      i += 2;
      continue;
    }
    if (arg === "--") {
      state.forwardArgs.push(...rawArgs.slice(i + 1));
      break;
    }
    if (arg.startsWith("-")) {
      fail(`未知选项: ${arg}`);
    }
    if (!state.sprite) {
      state.sprite = arg;
      i += 1;
      continue;
    }
    state.forwardArgs.push(arg);
    i += 1;
  }

  return state;
}

function main() {
  const args = parseArgs(process.argv.slice(2));

  if (args.list) {
    listSprites();
    return;
  }

  if (args.setDefault) {
    ensureReady();
    setDefault(args.setDefault);
    return;
  }

  if (args.show) {
    showCurrent(args.sprite);
    return;
  }

  ensureReady();

  const sprite = args.sprite || getDefault();
  if (!sprite) {
    fail(`错误: 未指定 sprite，也未设置默认 sprite\n使用 ${COMMAND_NAME} -l 查看可用 sprite，${COMMAND_NAME} -d <名> 设为默认`);
  }

  const spriteDir = path.join(SPRITES_DIR, sprite);
  if (!fileExists(spriteDir)) {
    fail(`错误: sprite '${sprite}' 不存在\n使用 ${COMMAND_NAME} -l 查看可用 sprite`);
  }

  const config = getSpriteConfig(sprite);
  const cli = config.cli || "opencode";
  syncSkills(sprite);

  if (cli === "claude") {
    const forwardArgs = [...args.forwardArgs];
    if (args.autoMode) {
      forwardArgs.unshift("bypassPermissions");
      forwardArgs.unshift("--permission-mode");
    }
    const env = {
      CLAUDE_CONFIG_DIR: spriteDir,
    };
    const provider = config.provider || "";
    const apiKey = provider ? getProviderValue(provider, "api_key") : "";
    const baseUrl = provider ? getProviderValue(provider, "base_url") : "";
    if (apiKey) {
      env.ANTHROPIC_API_KEY = apiKey;
    }
    if (baseUrl) {
      env.ANTHROPIC_BASE_URL = baseUrl;
    }
    if (config.model) {
      forwardArgs.unshift(config.model);
      forwardArgs.unshift("--model");
    }
    const mcpServers = syncMcp(sprite);
    if (Object.keys(mcpServers).length > 0) {
      const mcpJson = buildClaudeMcpJson(mcpServers);
      fs.writeFileSync(path.join(spriteDir, ".mcp.json"), JSON.stringify(mcpJson, null, 2), "utf8");
    }
    runCommand("claude", forwardArgs, env);
  }

  if (cli === "opencode") {
    runCommand("opencode", args.forwardArgs, {
      OPENCODE_CONFIG_DIR: spriteDir,
      OPENCODE_CONFIG_CONTENT: buildOpenCodeConfig(sprite, args.autoMode),
    });
  }

  fail(`错误: 不支持的 cli 类型 '${cli}'`);
}

main();
