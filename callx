#!/usr/bin/env node

const fs = require("fs");
const path = require("path");
const { spawnSync } = require("child_process");
const {
  CONFIG_BASE,
  PROVIDERS_FILE,
  SPRITES_DIR,
  buildClaudeMcpJson,
  buildOpenCodeConfig,
  ensureReady,
  fileExists,
  getDefault,
  getProvider,
  getProviderValue,
  getSpriteConfig,
  listSpriteNames,
  setDefault,
  syncMcp,
  syncSkills,
} = require("./lib/runtime");

const PACKAGE_NAME = "@greenhill/callx";
const COMMAND_NAME = "call";

function ensureReadyOrFail() {
  const bootstrapped = ensureReady();
  if (bootstrapped) {
    console.error(`已初始化配置目录: ${CONFIG_BASE}`);
    console.error(`请编辑: ${PROVIDERS_FILE}`);
  }
  if (!fileExists(PROVIDERS_FILE)) {
    fail(`错误: 未找到 ${PROVIDERS_FILE}`);
  }
}

function listSprites() {
  ensureReadyOrFail();
  console.log("可用 sprites:");
  if (!fileExists(SPRITES_DIR)) {
    return;
  }

  for (const name of listSpriteNames()) {
    const config = getSpriteConfig(name);
    const cli = config.cli || "opencode";
    const provider = config.provider || "-";
    const model = config.model || "-";
    const mcpCount = Array.isArray(config.mcp_links) ? config.mcp_links.length : 0;
    console.log(`  ${name.padEnd(20)} [${cli.padEnd(10)}] provider=${provider.padEnd(12)} model=${model} mcp=${mcpCount}`);
  }
}

function showCurrent(selectedSprite) {
  ensureReadyOrFail();
  const current = selectedSprite || getDefault();
  if (!current) {
    fail(`未设置默认 sprite，请先运行 ${COMMAND_NAME} -d <名>`);
  }

  const config = getSpriteConfig(current);
  const provider = config.provider || "-";
  const baseUrl = provider !== "-" ? getProviderValue(provider, "base_url") || "-" : "-";
  const providerRemark = provider !== "-" ? getProvider(provider).remark || "-" : "-";

  console.log(`当前 sprite: ${current}`);
  console.log(`  CLI:      ${config.cli || "opencode"}`);
  console.log(`  Provider: ${provider}`);
  console.log(`  Remark:   ${providerRemark}`);
  console.log(`  Model:    ${config.model || "-"}`);
  console.log(`  Base URL: ${baseUrl}`);
  console.log("  Key:      (stored in providers.json)");
  const mcpLinks = Array.isArray(config.mcp_links) ? config.mcp_links : [];
  console.log(`  MCP:      ${mcpLinks.length > 0 ? mcpLinks.join(", ") : "-"}`);
}

function showHelp() {
  console.log(`callx — AI 环境切换工具（支持 claude / opencode）

用法:
  ${COMMAND_NAME} [选项] [sprite 名] [-- 参数...]

选项:
  -l, --list          列出所有可用 sprite
  -d, --default <名>  设置默认 sprite
  -a, --auto          自动执行模式（Claude 会追加 --dangerously-skip-permissions）
  -s, --show          显示当前 sprite 配置
  update              通过 npm 更新 ${COMMAND_NAME}
  -h, --help          显示帮助

示例:
  ${COMMAND_NAME} -l
  ${COMMAND_NAME} -d open-01
  ${COMMAND_NAME}
  ${COMMAND_NAME} claude-01
  ${COMMAND_NAME} open-01 -a run "hi"
  ${COMMAND_NAME} update`);
}

function fail(message) {
  console.error(message);
  process.exit(1);
}

function runCommand(command, args, extraEnv = {}) {
  const result = spawnSync(command, args, {
    stdio: "inherit",
    env: { ...process.env, ...extraEnv },
  });

  if (result.error) {
    if (result.error.code === "ENOENT") {
      fail(`错误: 未找到命令 '${command}'`);
    }
    fail(result.error.message);
  }

  process.exit(result.status === null ? 1 : result.status);
}

function updateSelf() {
  const npmCmd = process.platform === "win32" ? "npm.cmd" : "npm";
  runCommand(npmCmd, ["install", "-g", `${PACKAGE_NAME}@latest`]);
}

function parseArgs(rawArgs) {
  const state = {
    sprite: "",
    autoMode: false,
    show: false,
    list: false,
    setDefault: "",
    forwardArgs: [],
  };

  let i = 0;
  while (i < rawArgs.length) {
    const arg = rawArgs[i];
    if (arg === "update") {
      updateSelf();
    }
    if (arg === "-l" || arg === "--list") {
      state.list = true;
      i += 1;
      continue;
    }
    if (arg === "-s" || arg === "--show") {
      state.show = true;
      i += 1;
      continue;
    }
    if (arg === "-h" || arg === "--help") {
      showHelp();
      process.exit(0);
    }
    if (arg === "-a" || arg === "--auto") {
      state.autoMode = true;
      i += 1;
      continue;
    }
    if (arg === "-d" || arg === "--default") {
      if (!rawArgs[i + 1]) {
        fail("错误: --default 需要一个 sprite 名称");
      }
      state.setDefault = rawArgs[i + 1];
      i += 2;
      continue;
    }
    if (arg === "--") {
      state.forwardArgs.push(...rawArgs.slice(i + 1));
      break;
    }
    if (arg.startsWith("-")) {
      fail(`未知选项: ${arg}`);
    }
    if (!state.sprite) {
      state.sprite = arg;
      i += 1;
      continue;
    }
    state.forwardArgs.push(arg);
    i += 1;
  }

  return state;
}

function main() {
  const args = parseArgs(process.argv.slice(2));

  if (args.list) {
    listSprites();
    return;
  }

  if (args.setDefault) {
    ensureReadyOrFail();
    try {
      setDefault(args.setDefault);
    } catch (error) {
      fail(`错误: ${error.message}`);
    }
    return;
  }

  if (args.show) {
    showCurrent(args.sprite);
    return;
  }

  ensureReadyOrFail();

  const sprite = args.sprite || getDefault();
  if (!sprite) {
    fail(`错误: 未指定 sprite，也未设置默认 sprite\n使用 ${COMMAND_NAME} -l 查看可用 sprite，${COMMAND_NAME} -d <名> 设为默认`);
  }

  const spriteDir = path.join(SPRITES_DIR, sprite);
  if (!fileExists(spriteDir)) {
    fail(`错误: sprite '${sprite}' 不存在\n使用 ${COMMAND_NAME} -l 查看可用 sprite`);
  }

  const config = getSpriteConfig(sprite);
  const cli = config.cli || "opencode";
  syncSkills(sprite);

  if (cli === "claude") {
    const forwardArgs = [...args.forwardArgs];
    if (args.autoMode) {
      forwardArgs.unshift("--dangerously-skip-permissions");
    }
    const env = {
      CLAUDE_CONFIG_DIR: spriteDir,
    };
    const provider = config.provider || "";
    const apiKey = provider ? getProviderValue(provider, "api_key") : "";
    const baseUrl = provider ? getProviderValue(provider, "base_url") : "";
    if (apiKey) {
      env.ANTHROPIC_API_KEY = apiKey;
    }
    if (baseUrl) {
      env.ANTHROPIC_BASE_URL = baseUrl;
    }
    if (config.model) {
      forwardArgs.unshift(config.model);
      forwardArgs.unshift("--model");
    }
    const mcpServers = syncMcp(sprite);
    if (Object.keys(mcpServers).length > 0) {
      const mcpJson = buildClaudeMcpJson(mcpServers);
      fs.writeFileSync(path.join(spriteDir, ".mcp.json"), JSON.stringify(mcpJson, null, 2), "utf8");
    }
    runCommand("claude", forwardArgs, env);
  }

  if (cli === "opencode") {
    runCommand("opencode", args.forwardArgs, {
      OPENCODE_CONFIG_DIR: spriteDir,
      OPENCODE_CONFIG_CONTENT: buildOpenCodeConfig(sprite, args.autoMode),
    });
  }

  fail(`错误: 不支持的 cli 类型 '${cli}'`);
}

main();
